{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "background"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://*/*"
        },
        {
          "url": "http://127.0.0.1:4096/*"
        }
      ]
    },
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "http://*/*"
        },
        {
          "url": "http://127.0.0.1:4096/*"
        }
      ]
    }
  ]
}
